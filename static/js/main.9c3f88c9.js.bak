//# sourceMappingURL=main.9c3f88c9.js.map


// ── UNIFIED ROOM CENTER MODAL ──────────────────────────────
(function () {
    'use strict';
    let modalOpen = false;
    window.addEventListener('hashchange', function (e) {
        if (window.location.hash.startsWith('#room/')) {
            window.location.href = './room/' + window.location.hash;
        }
    }, true);

    function createRoomCenterModal() {

        const modalHTML = `
      <style>
        #rc-overlay {
          display: none; position: fixed; inset: 0;
          background: rgba(0,0,0,0.88); backdrop-filter: blur(12px);
          z-index: 10000; justify-content: center; align-items: center;
        }
        #rc-box {
          background: #0e0e12; border: 1px solid rgba(255,255,255,0.08);
          border-radius: 28px; width: 92%; max-width: 440px;
          box-shadow: 0 40px 100px rgba(0,0,0,0.9); overflow: hidden;
          animation: rcUp 0.35s cubic-bezier(0.16,1,0.3,1) both;
        }
        @keyframes rcUp { from { opacity:0; transform: translateY(30px) scale(0.95); } to { opacity:1; transform: translateY(0) scale(1); } }
        @keyframes rcDown { from { opacity:1; transform: translateY(0) scale(1); } to { opacity:0; transform: translateY(30px) scale(0.95); } }
        @keyframes rcFadeIn { from { opacity:0; } to { opacity:1; } }
        @keyframes rcFadeOut { from { opacity:1; } to { opacity:0; } }

        #rc-overlay.open { display: flex; animation: rcFadeIn 0.3s ease-out both; }
        #rc-overlay.closing { animation: rcFadeOut 0.3s ease-in both; }
        #rc-box.closing { animation: rcDown 0.3s cubic-bezier(0.16,1,0.3,1) both; }
        
        #rc-header {
           padding: 28px 28px 12px; display: flex; justify-content: space-between; align-items: center;
        }
        #rc-title { color: #fff; font-size: 22px; font-weight: 800; font-family: 'Syne', sans-serif; margin: 0; letter-spacing: -0.5px; }
        #rc-close { background: rgba(255,255,255,0.05); border: none; width: 32px; height: 32px; border-radius: 50%; color: #888; font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
        #rc-close:hover { background: rgba(255,255,255,0.1); color: #fff; }
        
        #rc-body { padding: 12px 28px 28px; }
        
        .rc-opt {
          background: #16161c; border: 1px solid rgba(255,255,255,0.06);
          border-radius: 22px; padding: 20px; margin-bottom: 12px;
          cursor: pointer; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
          display: flex; flex-direction: column; gap: 0; position: relative; overflow: hidden;
        }
        .rc-opt:hover { border-color: rgba(232,25,44,0.4); background: rgba(232,25,44,0.03); transform: translateY(-2px); }
        .rc-opt.active { border-color: #E8192C; box-shadow: 0 0 0 4px rgba(232,25,44,0.1); background: rgba(232,25,44,0.06); }
        
        .rc-opt-row { display: flex; align-items: center; gap: 16px; width: 100%; }
        
        .rc-icon {
          width: 48px; height: 48px; border-radius: 14px; background: rgba(255,255,255,0.04);
          display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.3s;
          color: #888;
        }
        .rc-opt:hover .rc-icon { background: #E8192C; color: #fff; box-shadow: 0 4px 12px rgba(232,25,44,0.3); }
        
        .rc-info h4 { color: #fff; margin: 0; font-size: 16px; font-weight: 700; font-family: 'Syne', sans-serif; }
        .rc-info p { color: #5a5a6e; margin: 3px 0 0; font-size: 12px; font-family: 'Inter', sans-serif; }
        
        /* Join Specific */
        #rc-join-expand { display: none; margin-top: 24px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.06); width: 100%; animation: rcSlideDown 0.3s ease-out; }
        @keyframes rcSlideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
        
        .rc-code-grid { display: flex; gap: 8px; justify-content: center; margin-bottom: 20px; }
        .rc-code-box {
          width: 42px; height: 54px; background: #08080a; border: 2px solid #2a2a35;
          border-radius: 12px; color: #fff; font-size: 24px; font-weight: 800;
          text-align: center; text-transform: uppercase; outline: none; transition: all 0.2s;
          font-family: 'Inter', sans-serif;
        }
        .rc-code-box:focus { border-color: #E8192C; box-shadow: 0 0 15px rgba(232,25,44,0.25); background: #000; }
        
        #rc-submit-btn {
          width: 100%; padding: 15px; background: #E8192C; color: #fff; border: none;
          border-radius: 14px; font-weight: 800; font-family: 'Syne', sans-serif; font-size: 15px;
          cursor: pointer; box-shadow: 0 8px 20px rgba(232,25,44,0.3); transition: all 0.2s;
          display: flex; align-items: center; justify-content: center; gap: 10px;
        }
        #rc-submit-btn:hover { background: #ff1f33; transform: translateY(-2px); box-shadow: 0 10px 25px rgba(232,25,44,0.4); }
        
        #rc-rejoin { display: none; }
        .rc-badge { background: rgba(232,25,44,0.15); color: #E8192C; padding: 2px 8px; border-radius: 6px; font-family: monospace; font-size: 11px; margin-left: 8px; font-weight: 800; border: 1px solid rgba(232,25,44,0.2); }
      </style>
      </style>

      <div id="rc-overlay">
        <div id="rc-box">
          <div id="rc-header">
            <h2 id="rc-title">${window.i18n.t('roomCenter.title')}</h2>
            <button id="rc-close">✕</button>
          </div>
          <div id="rc-body">
            
            <div id="rc-rejoin" class="rc-opt">
               <div class="rc-opt-row">
                 <div class="rc-icon">
                   <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.32"/></svg>
                 </div>
                 <div class="rc-info">
                   <h4 id="rc-rejoin-text">${window.i18n.t('roomCenter.rejoin')} <span id="rc-badge-code" class="rc-badge"></span></h4>
                   <p id="rc-rejoin-desc">${window.i18n.t('roomCenter.rejoinDesc')}</p>
                 </div>
               </div>
            </div>

            <div id="rc-create-opt" class="rc-opt">
               <div class="rc-opt-row">
                 <div class="rc-icon">
                   <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z" /><rect x="1" y="5" width="15" height="14" rx="2" ry="2" /><line x1="8.5" y1="9" x2="8.5" y2="15" /><line x1="5.5" y1="12" x2="11.5" y2="12" /></svg>
                 </div>
                 <div class="rc-info">
                   <h4 id="rc-create-text">${window.i18n.t('roomCenter.create')}</h4>
                   <p id="rc-create-desc">${window.i18n.t('roomCenter.createDesc')}</p>
                 </div>
               </div>
            </div>

            <div id="rc-join-opt" class="rc-opt">
               <div class="rc-opt-row">
                 <div class="rc-icon">
                   <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                 </div>
                 <div class="rc-info">
                   <h4 id="rc-join-text">${window.i18n.t('roomCenter.join')}</h4>
                   <p id="rc-join-desc">${window.i18n.t('roomCenter.joinDesc')}</p>
                 </div>
               </div>
               <div id="rc-join-expand" onclick="event.stopPropagation()">
                  <div class="rc-code-grid">
                    <input class="rc-code-box" maxlength="1" inputmode="text" autocomplete="off">
                    <input class="rc-code-box" maxlength="1" inputmode="text" autocomplete="off">
                    <input class="rc-code-box" maxlength="1" inputmode="text" autocomplete="off">
                    <input class="rc-code-box" maxlength="1" inputmode="text" autocomplete="off">
                    <input class="rc-code-box" maxlength="1" inputmode="text" autocomplete="off">
                    <input class="rc-code-box" maxlength="1" inputmode="text" autocomplete="off">
                  </div>
                  <button id="rc-submit-btn">${window.i18n.t('roomCenter.submit')}</button>
               </div>
            </div>
            
          </div>
        </div>
      </div>
      `;
        document.body.insertAdjacentHTML('beforeend', modalHTML);

        const overlay = document.getElementById('rc-overlay');
        const rejoinOpt = document.getElementById('rc-rejoin');
        const createOpt = document.getElementById('rc-create-opt');
        const joinOpt = document.getElementById('rc-join-opt');
        const joinExpand = document.getElementById('rc-join-expand');
        const submitBtn = document.getElementById('rc-submit-btn');
        const boxes = Array.from(overlay.querySelectorAll('.rc-code-box'));

        function openModal() {
            // Refresh localization strings
            document.getElementById('rc-title').innerText = window.i18n.t('roomCenter.title');
            document.getElementById('rc-rejoin-text').childNodes[0].textContent = window.i18n.t('roomCenter.rejoin') + ' ';
            document.getElementById('rc-rejoin-desc').innerText = window.i18n.t('roomCenter.rejoinDesc');
            document.getElementById('rc-create-text').innerText = window.i18n.t('roomCenter.create');
            document.getElementById('rc-create-desc').innerText = window.i18n.t('roomCenter.createDesc');
            document.getElementById('rc-join-text').innerText = window.i18n.t('roomCenter.join');
            document.getElementById('rc-join-desc').innerText = window.i18n.t('roomCenter.joinDesc');
            document.getElementById('rc-submit-btn').innerText = window.i18n.t('roomCenter.submit');

            const savedCode = sessionStorage.getItem('roomCode');
            if (savedCode) {
                rejoinOpt.style.display = 'flex';
                document.getElementById('rc-badge-code').textContent = savedCode;
            } else {
                rejoinOpt.style.display = 'none';
            }
            overlay.classList.add('open');
            modalOpen = true;
        }

        function closeModal() {
            overlay.classList.add('closing');
            document.getElementById('rc-box').classList.add('closing');
            setTimeout(() => {
                overlay.classList.remove('open', 'closing');
                document.getElementById('rc-box').classList.remove('closing');
                joinExpand.style.display = 'none';
                boxes.forEach(b => b.value = '');
                modalOpen = false;
            }, 300);
        }

        document.getElementById('rc-close').onclick = closeModal;
        overlay.onclick = (e) => { if (e.target === overlay) closeModal(); };
        window.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modalOpen) closeModal(); });

        rejoinOpt.onclick = () => { window.location.href = './room/'; };

        createOpt.onclick = () => {
            const newId = Math.random().toString(36).substring(2, 8).toUpperCase();
            sessionStorage.setItem('roomCode', newId);
            sessionStorage.removeItem('pendingRoomCode');
            window.location.href = './room/';
        };

        joinOpt.onclick = () => {
            if (joinExpand.style.display === 'block') return;
            joinExpand.style.display = 'block';
            setTimeout(() => boxes[0].focus(), 100);
        };

        boxes.forEach((box, i) => {
            box.oninput = () => {
                box.value = box.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
                if (box.value && i < boxes.length - 1) boxes[i + 1].focus();
            };
            box.onkeydown = (e) => {
                if (e.key === 'Backspace' && !box.value && i > 0) boxes[i - 1].focus();
                if (e.key === 'Enter' && boxes.every(b => b.value)) submitBtn.click();
            };
            box.onpaste = (e) => {
                e.preventDefault();
                const text = (e.clipboardData || window.clipboardData).getData('text').toUpperCase().replace(/[^A-Z0-9]/g, '');
                text.split('').slice(0, 6).forEach((ch, j) => { if (boxes[i + j]) boxes[i + j].value = ch; });
                const next = Math.min(i + text.length, boxes.length - 1);
                boxes[next].focus();
            };
        });

        submitBtn.onclick = () => {
            const code = boxes.map(b => b.value).join('');
            if (code.length === 6) {
                window.location.href = `./room/#room/${code}`;
            }
        };

        window.openRoomCenter = openModal;

    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", createRoomCenterModal);
    } else {
        createRoomCenterModal();
    }
})();
